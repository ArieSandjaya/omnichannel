# App
APP_ENV=development
APP_PORT=8080
MOCK_MODE=true

# Database (Supabase / PostgreSQL)
DATABASE_URL=postgresql://postgres:password@localhost:5432/omnichannel?sslmode=disable

# Supabase
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Redis (Upstash)
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-this-to-a-32-char-secret!!
JWT_EXPIRES_IN=168h

# Domain (untuk subdomain storefront)
BASE_DOMAIN=localhost

# Marketplace
SHOPEE_PARTNER_ID=
SHOPEE_PARTNER_KEY=
TOKOPEDIA_CLIENT_ID=
TOKOPEDIA_CLIENT_SECRET=
TIKTOK_APP_KEY=
TIKTOK_APP_SECRET=
