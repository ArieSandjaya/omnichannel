# Application
APP_ENV=development
APP_PORT=8080
APP_URL=http://localhost:8080
JWT_SECRET=change_me_to_a_long_random_secret

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=postgres
DB_NAME=omnichannel_db
DB_SSL_MODE=disable

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# Xendit Payment Gateway
# Get keys at: https://dashboard.xendit.co/settings/developers
XENDIT_SECRET_KEY=xnd_development_xxxxxxxxxxxxxxxxxxxx
XENDIT_WEBHOOK_TOKEN=your_xendit_webhook_verification_token
XENDIT_QRIS_CALLBACK_URL=https://yourdomain.com/webhooks/xendit/qris
XENDIT_VA_CALLBACK_URL=https://yourdomain.com/webhooks/xendit/virtual-account
QRIS_EXPIRY_SECONDS=3600
VA_EXPIRY_HOURS=24
# Supported banks: BCA, BNI, BRI, MANDIRI, PERMATA, BSI
XENDIT_VA_BANKS=BCA,BNI,BRI,MANDIRI

# Biteship Shipping API
# Get keys at: https://app.biteship.com/settings/api
BITESHIP_API_KEY=biteship_test.xxxxxxxxxxxxxxxxxxxx
BITESHIP_API_URL=https://api.biteship.com/v1
BITESHIP_WEBHOOK_SECRET=your_biteship_hmac_webhook_secret
